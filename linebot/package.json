{
  "name": "linebot-blog-publisher",
  "version": "1.0.0",
  "description": "LINE Bot for automated Hexo blog publishing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:lambda": "npm run build && npm run package:lambda",
    "package:lambda": "cd dist && zip -r ../lambda-deployment.zip . && cd .. && zip -r lambda-deployment.zip node_modules",
    "deploy": "bash deploy.sh",
    "deploy:windows": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.975.0",
    "@line/bot-sdk": "^9.3.0",
    "@octokit/rest": "^20.0.2",
    "js-yaml": "^4.1.0",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
