# Environment Configuration
# AWS Lambda deployment only

# LINE Bot Configuration
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_blog_repository_name

# Blog Configuration
BLOG_BASE_URL=https://your-blog-domain.com
BLOG_IMAGE_BASE_PATH=/images

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=linebot-sessions
S3_AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=linebot-temp-images-your-unique-id

# Development
NODE_ENV=development